{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firebase-rules.json",
      "**/.*",
      "**/node_modules/**",
      "*.zip",
      "*backup*"
    ],
    "headers": [
      {
        "source": "/sw.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "**/*.@(js|css|png|json)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=3600"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "database": {
    "rules": "firebase-rules.json"
  }
}